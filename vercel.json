{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "functions": {
    "api/ssr.js": {
      "includeFiles": "dist/server/**"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "caramelinho.com"
        }
      ],
      "status": 301,
      "dest": "https://www.caramelinho.com/$1"
    },
    {
      "src": "/ads.txt",
      "headers": {
        "Content-Type": "text/plain; charset=utf-8",
        "Cache-Control": "public, max-age=3600"
      },
      "dest": "/ads.txt"
    },
    { "src": "/perfil", "dest": "/index.html" },
    { "src": "/entrar", "dest": "/index.html" },
    { "src": "/cadastro", "dest": "/index.html" },
    { "src": "/redefinir-senha", "dest": "/index.html" },
    { "src": "/negocio/wizard", "dest": "/index.html" },
    { "src": "/preview/negocio/(.*)", "dest": "/index.html" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/sitemaps/businesses.xml", "dest": "/api/sitemap-businesses" },

    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/api/ssr" }
  ]
}
