{
    "name": "quero-um-website-portal-que-futuramente-ser-tamb",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "generate:sitemaps": "node scripts/generate-sitemaps.mjs",
        "prebuild": "npm run generate:sitemaps",
        "predev": "npm run generate:sitemaps",
        "dev": "vike dev --host 0.0.0.0",
        "build": "vike build",
        "build:prerender": "vike build",
        "prepreview": "npm run check:encoding",
        "lint": "eslint .",
        "preview": "vike preview --host 0.0.0.0",
        "test:search": "vitest run src/lib/search/businessSearch.test.ts",
        "test:events": "vitest run src/lib/search/eventSearch.test.ts",
        "check:encoding": "node scripts/check-encoding.mjs",
        "fix:encoding": "node scripts/fix-encoding.mjs",
        "migrate:webp": "node scripts/migrate-images-to-webp.mjs",
        "migrate:webp:db": "node scripts/migrate-db-image-urls-to-webp.mjs"
    },
    "reactSnap": {
        "source": "dist",
        "include": [
            "/",
            "/buscar",
            "/sobre",
            "/contato",
            "/privacidade",
            "/termos",
            "/negocio-verificado"
        ],
        "skipThirdPartyRequests": true,
        "puppeteerArgs": [
            "--no-sandbox",
            "--disable-setuid-sandbox"
        ]
    },
    "dependencies": {
        "@fontsource/inter": "^5.2.8",
        "@radix-ui/react-avatar": "^1.1.11",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@supabase/supabase-js": "^2.49.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "0.454.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-router-dom": "^7.14.2",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "vike": "^0.4.259"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/google.maps": "^3.58.1",
        "@types/node": "^24.12.2",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "@vitejs/plugin-react": "^4.3.4",
        "autoprefixer": "^10.4.20",
        "eslint": "^10.2.1",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.5.0",
        "postcss": "^8.4.47",
        "react-snap": "^1.23.0",
        "sharp": "^0.34.5",
        "supabase": "^2.98.2",
        "tailwindcss": "^3.4.14",
        "tailwindcss-animate": "^1.0.7",
        "typescript": "^5.6.3",
        "typescript-eslint": "^8.58.2",
        "vite": "^5.4.11",
        "vitest": "^4.1.7"
    }
}
